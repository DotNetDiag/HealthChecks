<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(ExtendedLibraryTargetFrameworks)</TargetFrameworks>
    <PackageTags>$(PackageTags);SignalR</PackageTags>
    <Description>HealthChecks.SignalR is the health check package for SignalR.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Client" VersionOverride="8.0.*" Condition="'$(TargetFramework)' != 'net10.0'" />
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Client" VersionOverride="10.0.*" Condition="'$(TargetFramework)' == 'net10.0'" />
  </ItemGroup>

</Project>

